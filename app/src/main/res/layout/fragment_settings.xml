<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="16dp">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back"
        android:contentDescription="@string/back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/settings_title"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFFFF"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Sound toggle -->
    <TextView
        android:id="@+id/tv_sound_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/sound_effects"
        android:textSize="16sp"
        android:textColor="#DDFFFFFF"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switch_sound" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_sound"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/tv_sound_label"
        app:layout_constraintBottom_toBottomOf="@id/tv_sound_label"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Music toggle -->
    <TextView
        android:id="@+id/tv_music_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/music"
        android:textSize="16sp"
        android:textColor="#DDFFFFFF"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_sound_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switch_music" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_music"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/tv_music_label"
        app:layout_constraintBottom_toBottomOf="@id/tv_music_label"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Vibration toggle -->
    <TextView
        android:id="@+id/tv_vibration_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/vibration"
        android:textSize="16sp"
        android:textColor="#DDFFFFFF"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/tv_music_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/switch_vibration" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_vibration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/tv_vibration_label"
        app:layout_constraintBottom_toBottomOf="@id/tv_vibration_label"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Remove ads button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_remove_ads"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:text="@string/remove_ads"
        android:textColor="#FF0D1B2A"
        app:backgroundTint="#FFFFD700"
        app:cornerRadius="24dp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/tv_vibration_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Version info -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/version_info"
        android:textSize="12sp"
        android:textColor="#66FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
