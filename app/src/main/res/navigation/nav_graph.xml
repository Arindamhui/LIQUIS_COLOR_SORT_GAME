<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Splash Screen Destination -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.liquidcolorsort.ui.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true"
            app:enterAnim="@anim/fade_in"
            app:exitAnim="@anim/fade_out" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.liquidcolorsort.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_home_to_levelSelect"
            app:destination="@id/levelSelectFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

        <action
            android:id="@+id/action_home_to_settings"
            app:destination="@id/settingsFragment"
            app:enterAnim="@anim/slide_in_up"
            app:exitAnim="@anim/fade_out"
            app:popEnterAnim="@anim/fade_in"
            app:popExitAnim="@anim/slide_out_down" />

    </fragment>

    <fragment
        android:id="@+id/levelSelectFragment"
        android:name="com.liquidcolorsort.ui.levelselect.LevelSelectFragment"
        android:label="Level Select"
        tools:layout="@layout/fragment_level_select">

        <action
            android:id="@+id/action_levelSelect_to_game"
            app:destination="@id/gameFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right" />

    </fragment>

    <fragment
        android:id="@+id/gameFragment"
        android:name="com.liquidcolorsort.ui.game.GameFragment"
        android:label="Game"
        tools:layout="@layout/fragment_game">

        <!-- Self-navigation for next level -->
        <action
            android:id="@+id/action_game_self"
            app:destination="@id/gameFragment"
            app:launchSingleTop="false"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left" />

        <argument
            android:name="levelId"
            app:argType="integer"
            android:defaultValue="1" />

    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.liquidcolorsort.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <!-- No-Internet Dialog Destination -->
    <dialog
        android:id="@+id/noInternetDialogFragment"
        android:name="com.liquidcolorsort.ui.dialog.NoInternetDialogFragment"
        android:label="No Internet"
        tools:layout="@layout/fragment_no_internet" />

</navigation>
